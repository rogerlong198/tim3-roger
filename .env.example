# ============================================================
# RECARGA TIM — Exemplo de variáveis de ambiente
# Copie este arquivo para `.env.local` e preencha com suas chaves.
# NUNCA commite .env.local.
# ============================================================

# Provider: "pagou" (produção) ou "mock" (testes sem chave)
PIX_PROVIDER=pagou

# ---------- Pagou (obrigatórias) ----------
PAGOU_SECRET_KEY=sk_live_...
PAGOU_PUBLIC_KEY=pk_live_...
PAGOU_API_URL=https://api.conta.pagou.ai/v1
PAGOU_WEBHOOK_SECRET=token-longo-qualquer

# ---------- Webhook ----------
# Em produção, URL pública da aplicação (Pagou precisa alcançar).
# Exemplo: https://recarga-tim.vercel.app
# Em dev local, deixe em branco — o server usa o origin da própria request.
# PIX_WEBHOOK_BASE_URL=

# ---------- Mock (só usado se PIX_PROVIDER=mock) ----------
# Tempo (ms) para o mock marcar como pago. Default 180000 (3 min)
PIX_MOCK_PAID_AFTER_MS=180000
